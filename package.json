{
  "name": "good_feedback",
  "version": "1.0.0",
  "private": true,
  "description": "学成反馈系统",
  "author": "",
  "scripts": {
    "build:alipay": "taro build --type alipay",
    "build:h5": "taro build --type h5",
    "build:qq": "taro build --type qq",
    "build:swan": "taro build --type swan",
    "build:tt": "taro build --type tt",
    "build:weapp": "taro build --type weapp",
    "ci:eslint": "eslint -f json src -o ./.ci/eslint.json",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:weapp": "npm run build:weapp -- --watch",
    "lint": "eslint . && stylelint --allow-empty-input \"**/*.{css,less,scss}\"",
    "lint:fix": "prettier --write . && eslint --fix . && stylelint --allow-empty-input --fix \"**/*.{css,less,scss}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,mjs,mts,ts,tsx,vue}": "eslint --fix",
    "*.{css,less,scss}": "stylelint --fix",
    "*.{cjs,css,cts,html,js,json,jsx,less,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}": "prettier --write"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "prettier": "prettier-config-ali",
  "stylelint": {
    "extends": [
      "stylelint-config-ali",
      "stylelint-prettier/recommended"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.21.5",
    "@tarojs/components": "4.0.9",
    "@tarojs/helper": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-platform-alipay": "4.0.9",
    "@tarojs/plugin-platform-h5": "4.0.9",
    "@tarojs/plugin-platform-jd": "4.0.9",
    "@tarojs/plugin-platform-qq": "4.0.9",
    "@tarojs/plugin-platform-swan": "4.0.9",
    "@tarojs/plugin-platform-tt": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/react": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sr-sdk-h5": "^1.3.1",
    "sr-sdk-wxapp": "^1.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/plugin-proposal-class-properties": "7.14.5",
    "@babel/preset-react": "^7.24.1",
    "@tarojs/cli": "4.0.9",
    "@tarojs/vite-runner": "4.0.9",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.1.0",
    "babel-preset-taro": "4.0.9",
    "eslint": "^9.39.2",
    "eslint-config-ali": "^16.5.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-taro": "4.0.9",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "less": "^4.1.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-config-ali": "^1.5.0",
    "react-refresh": "^0.11.0",
    "stylelint": "^16.26.1",
    "stylelint-config-ali": "^2.3.0",
    "stylelint-prettier": "^5.0.3",
    "terser": "^5.16.8",
    "vite": "^4.2.0"
  },
  "templateInfo": {
    "name": "youshu",
    "typescript": false,
    "css": "Less",
    "framework": "React"
  }
}
